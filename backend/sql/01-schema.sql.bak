-- ╔══════════════════════════════════════════════════════════════════════╗
-- ║  HYPR Commplan — Schema BigQuery (dataset: hypr_commplan)             ║
-- ║  Versão: 2026                                                          ║
-- ║                                                                        ║
-- ║  Todas as 11 tabelas commplan_* ficam no dataset isolado hypr_commplan║
-- ║  (não em hypr_sales_center) — separação de permissões e backup.        ║
-- ║                                                                        ║
-- ║  Tabelas EXTERNAS que o Commplan apenas lê/escreve cross-dataset:     ║
-- ║    - hypr_sales_center.checklists (write pelo Command, read pelo Compplan)║
-- ║    - hypr_sales_center.team_members (read+write — compartilhado)      ║
-- ║    - prod_prod_hypr_reporthub.campaign_results (read pra Loom auto)   ║
-- ╚══════════════════════════════════════════════════════════════════════╝
-- Substitua `site-hypr.hypr_commplan` pelo seu PROJECT.DATASET se diferente.

-- ── 0. Cria o dataset se não existir ──────────────────────────────────────
-- Localização southamerica-east1 (mesma região das outras plataformas HYPR).
CREATE SCHEMA IF NOT EXISTS `site-hypr.hypr_commplan`
OPTIONS(
  location = 'southamerica-east1',
  description = 'HYPR Commplan — cálculo de bônus do time CS (isolado)'
);

-- ── 1. Versionamento ──────────────────────────────────────────────────────
CREATE TABLE IF NOT EXISTS `site-hypr.hypr_commplan.commplan_versions` (
  id STRING NOT NULL,
  effective_from DATE NOT NULL,
  effective_to DATE NOT NULL,
  active BOOL NOT NULL,
  notes STRING,
  created_at TIMESTAMP NOT NULL,
  updated_at TIMESTAMP NOT NULL
);

-- ── 2. Catálogo de features (com tier) ────────────────────────────────────
CREATE TABLE IF NOT EXISTS `site-hypr.hypr_commplan.commplan_features_catalog` (
  feature_code STRING NOT NULL,
  display_name STRING NOT NULL,
  tier INT64 NOT NULL,
  version_id STRING NOT NULL,
  active BOOL NOT NULL,
  notes STRING,
  created_at TIMESTAMP NOT NULL,
  updated_at TIMESTAMP NOT NULL
);

-- ── 3. Clientes ABS (DV360 advertiser_ids) ────────────────────────────────
CREATE TABLE IF NOT EXISTS `site-hypr.hypr_commplan.commplan_abs_clients` (
  advertiser_id STRING NOT NULL,
  client_group STRING NOT NULL,
  display_name STRING NOT NULL,
  via_partner STRING,
  active BOOL NOT NULL,
  notes STRING,
  created_at TIMESTAMP NOT NULL,
  updated_at TIMESTAMP NOT NULL
);

-- ── 4. Catálogo de regras (PDF traduzido) ─────────────────────────────────
CREATE TABLE IF NOT EXISTS `site-hypr.hypr_commplan.commplan_rules` (
  id STRING NOT NULL,
  version_id STRING NOT NULL,
  category STRING NOT NULL,         -- 'pre_campaign'|'setup'|'optimization'|'account_mgmt'|'extras'|'onboarding'
  subcategory STRING,
  display_name STRING NOT NULL,
  display_order INT64,
  bonus_pct FLOAT64 NOT NULL,
  evaluation_mode STRING NOT NULL,  -- 'auto'|'manual'|'hybrid'
  condition_kind STRING NOT NULL,
  condition_payload JSON,
  cap_group STRING,
  cap_max_pct FLOAT64,
  exclusion_group STRING,
  active BOOL NOT NULL,
  created_at TIMESTAMP NOT NULL,
  updated_at TIMESTAMP NOT NULL
);

-- ── 5. Salário fixo dos CSs (close-and-insert, append-only) ───────────────
CREATE TABLE IF NOT EXISTS `site-hypr.hypr_commplan.commplan_cs_config` (
  cs_email STRING NOT NULL,
  fixed_salary_brl FLOAT64 NOT NULL,
  effective_from DATE NOT NULL,
  effective_to DATE,
  notes STRING,
  updated_by STRING NOT NULL,
  created_at TIMESTAMP NOT NULL,
  updated_at TIMESTAMP NOT NULL
);

-- ── 6. Mentorias (mentor → mentee) ────────────────────────────────────────
CREATE TABLE IF NOT EXISTS `site-hypr.hypr_commplan.commplan_mentorships` (
  id STRING NOT NULL,
  mentor_email STRING NOT NULL,
  mentee_email STRING NOT NULL,
  effective_from DATE NOT NULL,
  effective_to DATE,
  notes STRING,
  created_at TIMESTAMP NOT NULL
);

-- ── 7. Evidências manuais (claims dos CSs) ────────────────────────────────
CREATE TABLE IF NOT EXISTS `site-hypr.hypr_commplan.commplan_evidences` (
  id STRING NOT NULL,
  short_token STRING NOT NULL,
  cs_email STRING NOT NULL,
  rule_id STRING NOT NULL,
  status STRING NOT NULL,           -- 'claimed'|'approved'|'rejected'
  evidence_payload JSON,
  claimed_at TIMESTAMP NOT NULL,
  reviewed_by STRING,
  reviewed_at TIMESTAMP,
  review_notes STRING,
  created_at TIMESTAMP NOT NULL,
  updated_at TIMESTAMP NOT NULL
);

-- ── 7b. Catálogo de estudos (sazonais/temáticos) ──────────────────────────
-- Cada estudo tem um autor (CS responsável). Quando o CP marca no
-- checklist do Command que usou X estudo, o autor recebe o bônus.
CREATE TABLE IF NOT EXISTS `site-hypr.hypr_commplan.commplan_studies_catalog` (
  id STRING NOT NULL,
  version_id STRING NOT NULL,
  display_name STRING NOT NULL,
  author_email STRING NOT NULL,     -- quem GANHA o bônus
  celebration_date DATE,            -- data da data comemorativa (ex: 25/12 pra Natal)
  delivery_estimate STRING,         -- previsão tipo "01/2026", "08/2026"
  status STRING NOT NULL,           -- 'planejado' | 'em_progresso' | 'feito'
  link_url STRING,                  -- Google Doc do estudo
  active BOOL NOT NULL,
  notes STRING,
  created_at TIMESTAMP NOT NULL,
  updated_at TIMESTAMP NOT NULL
);

-- ── 8. Snapshot por campanha (computado pelo engine) ──────────────────────
CREATE TABLE IF NOT EXISTS `site-hypr.hypr_commplan.commplan_campaign_calc` (
  id STRING NOT NULL,
  cs_email STRING NOT NULL,
  short_token STRING NOT NULL,
  quarter STRING NOT NULL,
  version_id STRING NOT NULL,
  client_name STRING,
  campaign_name STRING,
  campaign_start_date DATE,
  campaign_end_date DATE,
  revenue_gross_brl FLOAT64,
  revenue_net_brl FLOAT64,
  rules_applied JSON,
  total_pct FLOAT64,
  bonus_amount_brl FLOAT64,
  mentor_email STRING,
  mentor_bonus_amount_brl FLOAT64,
  study_author_email STRING,
  study_author_bonus_amount_brl FLOAT64,
  computed_at TIMESTAMP NOT NULL,
  computed_by STRING
);

-- ── 9. Resumo por CS por quarter (snapshot agregado) ──────────────────────
CREATE TABLE IF NOT EXISTS `site-hypr.hypr_commplan.commplan_quarter_summary` (
  id STRING NOT NULL,
  cs_email STRING NOT NULL,
  quarter STRING NOT NULL,
  version_id STRING NOT NULL,
  bonus_from_own_campaigns_brl FLOAT64,
  bonus_from_mentorship_brl FLOAT64,
  bonus_from_studies_brl FLOAT64,
  bonus_gross_brl FLOAT64,
  fixed_salary_monthly_brl FLOAT64,
  salary_deduction_brl FLOAT64,
  bonus_net_brl FLOAT64,
  status STRING NOT NULL,           -- 'draft'|'pending_approval'|'approved'|'paid'
  campaigns_count INT64,
  evidences_pending_count INT64,
  computed_at TIMESTAMP NOT NULL,
  approved_by STRING,
  approved_at TIMESTAMP,
  paid_at TIMESTAMP,
  paid_by STRING,
  notes STRING,
  created_at TIMESTAMP NOT NULL,
  updated_at TIMESTAMP NOT NULL
);

-- ── 10. Audit log (toda mudança de admin passa por aqui) ──────────────────
CREATE TABLE IF NOT EXISTS `site-hypr.hypr_commplan.commplan_audit_log` (
  id STRING NOT NULL,
  entity_type STRING NOT NULL,
  entity_id STRING NOT NULL,
  action STRING NOT NULL,
  changed_by STRING NOT NULL,
  changed_at TIMESTAMP NOT NULL,
  before_value JSON,
  after_value JSON,
  notes STRING
);
